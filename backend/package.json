{
    "name": "modern-blue-collar-backend",
    "version": "2.0.0",
    "description": "White-label field service management backend — electrical, plumbing, HVAC, contracting",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "migrate": "npx prisma migrate dev",
        "migrate:prod": "npx prisma migrate deploy",
        "generate": "npx prisma generate",
        "seed:admin": "node seed_superadmin.js",
        "seed:prices": "node seed_pricebook.js",
        "seed:jobs": "node seed_jobs.js",
        "seed:apikey": "node seed_apikey.js",
        "seed:all": "node seed_superadmin.js && node seed_pricebook.js && node seed_jobs.js",
        "test": "node tests/api.test.js",
        "studio": "npx prisma studio"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1024.0",
        "@prisma/client": "^5.0.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "express-rate-limit": "^8.3.1",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "intuit-oauth": "^4.0.0",
        "jsonwebtoken": "^9.0.0",
        "node-cron": "^3.0.3",
        "nodemailer": "^6.9.3",
        "passport": "^0.6.0",
        "passport-google-oauth20": "^2.0.0",
        "prisma": "^5.0.0",
        "socket.io": "^4.8.3",
        "twilio": "^4.19.3"
    },
    "devDependencies": {
        "nodemon": "^3.0.2"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "license": "MIT"
}
