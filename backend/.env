# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Google OAuth (console.cloud.google.com) ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_secret_string_min_32_chars

# ─── QuickBooks Online (developer.intuit.com) ─────────────────────────────────
QB_CLIENT_ID=your_qb_client_id
QB_CLIENT_SECRET=your_qb_client_secret
QB_REDIRECT_URI=https://yourdomain.com/api/quickbooks/callback
QB_ENVIRONMENT=sandbox

# ─── Twilio SMS (twilio.com/console) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15550000000

# ─── Google Maps (console.cloud.google.com) ───────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Wasabi Cloud Backup (wasabi.com) ─────────────────────────────────────────
WASABI_BUCKET=david-lies-plumbing-backups
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.us-east-1.wasabisys.com

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
APP_URL=https://yourdomain.com
NODE_ENV=production

# ─── Branding / White-label tokens (see brand.config.js) ──────────────────────
BRAND_COMPANY_NAME=David Lies Plumbing Inc
BRAND_COMPANY_SLOGAN=Giving Your Plumbing a New Lies on Life
BRAND_COMPANY_PHONE=+13162418562
BRAND_COMPANY_EMAIL=office@davidliesplumbing.com
BRAND_COMPANY_ADDRESS=1420 S Sabin St, Wichita, KS 67209

# Trade type: electrical | plumbing | hvac | plumbing-hvac | contracting
BRAND_TRADE_TYPE=plumbing

# Technician label override (auto-derived from BRAND_TRADE_TYPE if blank)
BRAND_TECH_LABEL=Plumber

# Industry label for pricebook (auto-derived if blank)
BRAND_INDUSTRY_LABEL=Plumbing

# Theme colours (hex) — matched from davidliesplumbing.com
# Header/nav: steel blue, Logo accent: red, Nav: dark steel blue
BRAND_COLOR_PRIMARY="#38678f"
BRAND_COLOR_SECONDARY="#2c5577"
BRAND_COLOR_ACCENT="#c62828"
BRAND_COLOR_NAV_BG="#2c5577"
BRAND_COLOR_NAV_TEXT="#ffffff"
BRAND_COLOR_HEADER_BG="#38678f"
BRAND_COLOR_HEADER_TEXT="#ffffff"

# Default US state for customer address forms
BRAND_DEFAULT_STATE=KS

# Timezone for cron jobs
BRAND_TIMEZONE=America/Chicago
