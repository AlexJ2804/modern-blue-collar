# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Google OAuth (console.cloud.google.com) ──────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_random_secret_string_min_32_chars

# ─── QuickBooks Online (developer.intuit.com) ─────────────────────────────────
QB_CLIENT_ID=your_qb_client_id
QB_CLIENT_SECRET=your_qb_client_secret
QB_REDIRECT_URI=https://yourdomain.com/api/quickbooks/callback
QB_ENVIRONMENT=sandbox

# ─── Twilio SMS (twilio.com/console) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15550000000

# ─── Google Maps (console.cloud.google.com) ───────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
APP_URL=https://yourdomain.com
NODE_ENV=production

# ─── Branding / White-label tokens (see brand.config.js) ──────────────────────
BRAND_COMPANY_NAME=My Company LLC
BRAND_COMPANY_SLOGAN=Field Service Management
BRAND_COMPANY_PHONE=+15550001234
BRAND_COMPANY_EMAIL=office@mycompany.com
BRAND_COMPANY_ADDRESS=123 Main St, Anytown, KS 67000

# Trade type: electrical | plumbing | hvac | contracting
BRAND_TRADE_TYPE=electrical

# Technician label override (auto-derived from BRAND_TRADE_TYPE if blank)
BRAND_TECH_LABEL=

# Industry label for pricebook (auto-derived if blank)
BRAND_INDUSTRY_LABEL=

# Theme colours (hex) — quote values so # is not treated as a comment
BRAND_COLOR_PRIMARY="#f5a623"
BRAND_COLOR_SECONDARY="#1a1a2e"
BRAND_COLOR_ACCENT="#ffffff"
BRAND_COLOR_NAV_BG="#1a1a2e"
BRAND_COLOR_NAV_TEXT="#ffffff"
BRAND_COLOR_HEADER_BG="#f5a623"
BRAND_COLOR_HEADER_TEXT="#1a1a2e"

# Default US state for customer address forms
BRAND_DEFAULT_STATE=KS

# Timezone for cron jobs
BRAND_TIMEZONE=America/Chicago
